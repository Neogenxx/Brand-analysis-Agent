# ── Brand Analysis Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.

# LLM Provider: "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI — used for sentiment, theme extraction, and Agent Insights
OPENAI_API_KEY=sk-...

# Google Gemini — alternative to OpenAI
GEMINI_API_KEY=

# Model to use (for OpenAI)
LLM_MODEL=gpt-4o-mini

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
